generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  libraryItems     LibraryItem[]
  generationJobs   GenerationJob[]
  auditLogs        AuditLog[]
  products         Product[]
  characters       Character[]
  promptTemplates  PromptTemplate[]

  @@map("users")
}

model GenerationJob {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String   // "single_image" | "carousel" | "video"
  angle         String   // "fomo" | "social_proof" | ...
  status        String   @default("pending") // pending | processing | completed | failed
  inputPayload  Json     @map("input_payload")
  resultUrl     String?  @map("result_url")
  resultPrompt  String?  @map("result_prompt") @db.Text
  errorMessage  String?  @map("error_message") @db.Text
  costUsd       Float?   @map("cost_usd")
  apiUsed       String?  @map("api_used")
  durationMs    Int?     @map("duration_ms")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("generation_jobs")
}

model LibraryItem {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  jobId         String?  @map("job_id")
  type          String   // single_image | carousel | video
  angle         String?
  title         String
  imageUrl      String?  @map("image_url")
  videoUrl      String?  @map("video_url")
  prompt        String?  @db.Text
  copyHeadline  String?  @map("copy_headline")
  copySubtext   String?  @map("copy_subtext") @db.Text
  copyCta       String?  @map("copy_cta")
  metadata      Json?
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, createdAt(sort: Desc)])
  @@index([userId, type])
  @@map("library_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String   // login_success | login_fail | register | generation_started | generation_completed | library_save | library_delete
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Product {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?  @db.Text
  texture     String?
  photos      Json?
  price       Float?
  promoPrice  Float?   @map("promo_price")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("products")
}

model Character {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?  @db.Text
  photos      Json?    // array of base64 data URLs (max 10)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptTemplates PromptTemplate[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("characters")
}

// Reusable scene prompt templates — linked optionally to a character
model PromptTemplate {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  characterId    String?  @map("character_id")
  name           String
  sceneType      String   @map("scene_type")      // hook | body | cta | custom
  imagePrompt    String   @map("image_prompt") @db.Text
  voiceover      String?  @db.Text
  voiceDirection String?  @map("voice_direction")
  textOverlay    String?  @map("text_overlay")
  cameraMovement String?  @map("camera_movement")
  mood           String?
  style          String?  @db.Text
  negativePrompt String?  @map("negative_prompt") @db.Text
  tags           Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, characterId])
  @@map("prompt_templates")
}
