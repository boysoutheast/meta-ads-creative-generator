# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# apimart.ai
APIMART_API_KEY=your_apimart_api_key_here
APIMART_BASE_URL=https://apimart.ai/api/v1

# Image Generation Model (via apimart.ai - OpenAI-compatible)
IMAGE_MODEL=dall-e-3

# Video Generation Model (via apimart.ai)
VIDEO_MODEL=runway-gen3

# Vision/Analysis Model
VISION_MODEL=gpt-4o

# Upload settings
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# GeminiGen AI (for Create AI Reels — Grok video generation)
GEMINIGEN_API_KEY=your_geminigen_api_key_here

# Redis — session persistence for Reels (add Railway Redis plugin → copy URL here)
# Falls back to in-memory + /tmp file if not set (dev only)
REDIS_URL=redis://default:password@host:6379
